# Backend environment variables for Cloud Run
# Copy to .env.local for local development (never commit .env.local)

# GCS bucket name for document storage (created in me-central2)
GCS_BUCKET=YOUR_PROJECT_ID-pii-documents

# Comma-separated list of allowed CORS origins (no spaces)
CORS_ORIGINS=https://YOUR_PROJECT_ID.web.app,https://YOUR_PROJECT_ID.firebaseapp.com,https://YOUR_VUE_SITE_ID.web.app
