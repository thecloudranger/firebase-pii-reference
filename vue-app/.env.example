# Vite environment variables for Vue app
# Copy to .env.local and fill in your values (never commit .env.local)

# Cloud Run backend URL (me-central2)
# Get it from: gcloud run services describe dammam-backend --region me-central2 --format='value(status.url)'
VITE_BACKEND_URL=https://YOUR_CLOUD_RUN_URL.me-central2.run.app

# Firebase web app config
# Get all values from: firebase apps:sdkconfig WEB YOUR_APP_ID --project YOUR_PROJECT_ID
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_PROJECT_NUMBER
VITE_FIREBASE_APP_ID=your-app-id
